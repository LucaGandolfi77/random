[Unit]
Description=Atlas Telegram control bridge
Requires=atlas-control-server.service
After=atlas-control-server.service network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__ATLAS_ROOT__
EnvironmentFile=__ATLAS_ENV_FILE__
ExecStart=/usr/bin/env python3 __ATLAS_ROOT__/control-panel/telegram_control_bot.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target