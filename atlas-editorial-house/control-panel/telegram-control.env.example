# Copy this file to control-panel/telegram-control.env and fill in the Telegram values.
# The install-systemd-user-services.sh helper will reference that env file directly.

ATLAS_CONTROL_HOST=127.0.0.1
ATLAS_CONTROL_PORT=8765
ATLAS_CONTROL_PROFILE=atlas-editorial-house
ATLAS_CONTROL_SERVER=http://127.0.0.1:8765

# Optional but recommended. When set, the Telegram bridge authenticates to the local server.
ATLAS_CONTROL_TOKEN=

# Required to start the Telegram bridge.
ATLAS_TELEGRAM_BOT_TOKEN=

# Strongly recommended so only one trusted Telegram chat can control Atlas.
ATLAS_TELEGRAM_CHAT_ID=

ATLAS_TELEGRAM_POLL_TIMEOUT=30