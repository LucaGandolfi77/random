OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Dynasty Sim
OPENROUTER_HTTP_REFERER=https://localhost
# Primary model for agent reasoning (must be a free model)
DYNASTY_PRIMARY_MODEL=google/gemini-2.0-flash-exp:free
# Fallback model if primary is unavailable
DYNASTY_FALLBACK_MODEL=openrouter/free
# Log level for OpenRouter calls: DEBUG shows every call+timing, INFO shows OK/FAIL lines
# Omit or leave blank to suppress all client logs
DYNASTY_LOG_LEVEL=INFO
