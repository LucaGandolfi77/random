# ESP32 AI Radio Station Director - Configurazione backend

# OpenRouter API
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Token API per ESP32 (generare uno unico)
API_TOKEN=your-secret-device-token-here

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Radio Identity
STATION_NAME=Radio Gandolfi
STATION_TAGLINE=Suoni intelligenti da una stanza connessa
STATION_LANGUAGE=it
VOICE_STYLE=calmo, tech, elegante, leggermente ironico